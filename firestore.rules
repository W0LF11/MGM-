rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: Default Deny All
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable Secure Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Dynamic Role Resolvers with protection against recursion
    function isAdmin() {
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email == 'wolfsingh1110@gmail.com') ||
        ('email' in request.auth.token && request.auth.token.email == 'vishalpal@gmail.com') ||
        ('email' in request.auth.token && request.auth.token.email == 'admin@luckyplatform.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
      );
    }

    function isSupport() {
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email == 'wolfsingh1110@gmail.com') ||
        ('email' in request.auth.token && request.auth.token.email == 'vishalpal@gmail.com') ||
        ('email' in request.auth.token && request.auth.token.email == 'admin@luckyplatform.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'support'))
      );
    }

    // Entity Schema Validators
    function isValidUser(data) {
      return data.id is string && 
             data.username is string && data.username.size() >= 3 && data.username.size() <= 30 &&
             data.email is string && data.email.size() <= 100 &&
             data.balance is number && data.balance >= 0 &&
             data.bonusBalance is number && data.bonusBalance >= 0;
    }

    function isValidRequest(data) {
      return data.id is string && 
             data.userId is string && 
             data.username is string &&
             data.type is string && (data.type == 'deposit' || data.type == 'withdrawal') &&
             data.amount is number && data.amount > 0 &&
             data.status is string && (data.status == 'pending' || data.status == 'approved' || data.status == 'rejected') &&
             data.reference is string && data.reference.size() <= 200 &&
             data.gateway is string && data.gateway.size() <= 100 &&
             data.date is string;
    }

    function isValidTransaction(data) {
      return data.id is string && 
             data.userId is string && 
             data.username is string &&
             data.type is string && (data.type == 'deposit' || data.type == 'withdrawal' || data.type == 'bet' || data.type == 'win' || data.type == 'referral' || data.type == 'admin_adjustment' || data.type == 'credit_adjustment') &&
             data.amount is number && data.amount >= 0 &&
             data.status is string && (data.status == 'completed' || data.status == 'failed' || data.status == 'refunded' || data.status == 'rejected') &&
             data.reference is string && data.reference.size() <= 200 &&
             data.date is string;
    }

    function isValidBet(data) {
      return data.id is string && 
             data.gameId is string && 
             data.gameName is string &&
             data.userId is string && 
             data.username is string &&
             data.betAmount is number && data.betAmount > 0 &&
             data.winAmount is number && data.winAmount >= 0 &&
             data.multiplier is number && data.multiplier >= 0 &&
             data.status is string && (data.status == 'win' || data.status == 'loss') &&
             data.date is string;
    }

    function isValidBankAccount(data) {
      return data.id is string && 
             data.userId is string &&
             data.bankName is string && data.bankName.size() <= 100 &&
             data.accountHolder is string && data.accountHolder.size() <= 100 &&
             data.accountNumber is string && data.accountNumber.size() <= 50 &&
             data.routingCode is string && data.routingCode.size() <= 50;
    }

    function isValidNotification(data) {
      return data.id is string &&
             data.get('userId', '') is string &&
             data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 2000 &&
             data.type is string && (data.type == 'account' || data.type == 'wallet' || data.type == 'referral' || data.type == 'system' || data.type == 'achievement' || data.type == 'support') &&
             data.isRead is bool &&
             data.timestamp is string;
    }

    function isValidAuditLog(data) {
      return data.id is string &&
             data.userId is string &&
             data.type is string &&
             data.amount is number &&
             data.description is string && data.description.size() <= 1000 &&
             data.createdAt is string;
    }

    // COLLECTION: USERS
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || resource.data.referredBy == request.auth.uid || isAdmin() || isSupport());
      allow list: if isSignedIn() && (isAdmin() || isSupport() || resource.data.referredBy == request.auth.uid);
      allow create: if isSignedIn() && (
        (request.auth.uid == userId && 
         isValidUser(incoming()) &&
         (
           // Regular user
           (incoming().role == 'user' && 
            incoming().status == 'active' && 
            (incoming().balance == 10 || incoming().balance == 0) && 
            (incoming().bonusBalance == 50 || incoming().bonusBalance == 0)) ||
           // Explicit pre-registered admins
           (incoming().role == 'admin' &&
            (('email' in request.auth.token && request.auth.token.email == 'wolfsingh1110@gmail.com') ||
             ('email' in request.auth.token && request.auth.token.email == 'vishalpal@gmail.com') ||
             ('email' in request.auth.token && request.auth.token.email == 'admin@luckyplatform.com')) &&
            incoming().status == 'active' &&
            (incoming().balance == 10 || incoming().balance == 0) && 
            (incoming().bonusBalance == 50 || incoming().bonusBalance == 0)) ||
           // Secret admin creation
           (incoming().role == 'admin' &&
            incoming().get('adminCode', '') == 'MGM_ADMIN_SECRET_KEY_2026' &&
            incoming().status == 'active' &&
            incoming().balance == 0 &&
            incoming().bonusBalance == 0)
         )) ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        // Regular user self update: can change profile info, plus balance/bonusBalance for gameplay/payout transactions and rigging resets
        (request.auth.uid == userId && 
         incoming().diff(existing()).affectedKeys().hasOnly([
           'username', 'phone', 'avatar', 'isEmailVerified', 'isMobileVerified', 
           'balance', 'bonusBalance', 'password',
           'nextSpinResult', 'nextLuckyResult', 'nextDiceResult', 'nextCoinFlipResult', 
           'nextColorMatchResult', 'nextLuckySevenResult', 'nextCardClashResult', 'nextTreasureBoxResult', 
           'nextPuzzleArenaResult', 'nextQuizBattleResult', 'nextNumberRushResult', 'nextFortuneDrawResult',
           'diceOverrides', 'nextDiceTimeSlot', 'nextDiceWinPercentage', 'nextDiceLossPercentage'
         ])) ||
        // Admin overrides: full control over role, balances, credit rating, and profiles
        isAdmin()
      );
      allow delete: if false; // Profiles are permanent
    }

    // COLLECTION: REQUESTS (Deposits & Withdrawals Queue)
    match /requests/{requestId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isSupport());
      allow list: if isSignedIn() && (isSupport() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && 
                    isValidId(requestId) && 
                    isValidRequest(incoming()) && 
                    (incoming().userId == request.auth.uid || isAdmin()) && 
                    incoming().status == 'pending';
      allow update: if isSignedIn() && isValidId(requestId) && (
        // Only Admin/Support can approve/reject request submissions
        (isSupport() && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'approvedBy', 'rejectedBy', 'rejectionReason']) && 
         (incoming().status == 'approved' || incoming().status == 'rejected'))
      );
      allow delete: if false;
    }

    // COLLECTION: TRANSACTIONS (Financial Ledger Logs)
    match /transactions/{transactionId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isSupport());
      allow list: if isSignedIn() && (isSupport() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && 
                    isValidId(transactionId) && 
                    isValidTransaction(incoming()) && 
                    (incoming().userId == request.auth.uid || isAdmin());
      allow update, delete: if false; // Historical logs are strictly immutable
    }

    // COLLECTION: BETS (Gameplay Wager Records)
    match /bets/{betId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isSupport());
      allow list: if isSignedIn() && (isSupport() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && 
                    isValidId(betId) && 
                    isValidBet(incoming()) && 
                    incoming().userId == request.auth.uid;
      allow update, delete: if false; // Wager audits are immutable
    }

    // COLLECTION: BANK ACCOUNTS
    match /bankAccounts/{bankAccountId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isSupport());
      allow list: if isSignedIn() && (isSupport() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && 
                    isValidId(bankAccountId) && 
                    isValidBankAccount(incoming()) && 
                    incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && 
                    isValidId(bankAccountId) && 
                    isValidBankAccount(incoming()) && 
                    incoming().userId == request.auth.uid && 
                    existing().userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // COLLECTION: SUPPORT TICKETS
    match /tickets/{ticketId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isSupport());
      allow list: if isSignedIn() && (isSupport() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(ticketId) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid && incoming().userId == request.auth.uid) || 
        isSupport()
      );
      allow delete: if false;
    }

    // COLLECTION: ANNOUNCEMENTS (CMS)
    match /announcements/{announcementId} {
      allow read: if true; // Public announcements are visible to everyone
      allow write: if isSignedIn() && isAdmin();
    }

    // COLLECTION: AUDIT LOGS
    match /audit_logs/{logId} {
      allow read: if isSignedIn() && (isAdmin() || isSupport() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isAdmin() && isValidId(logId) && isValidAuditLog(incoming());
      allow update, delete: if false; // Permanent logs
    }

    // COLLECTION: NOTIFICATIONS
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || !resource.data.keys().hasAll(['userId']) || isAdmin() || isSupport());
      allow create: if isSignedIn() && isValidId(notifId) && isValidNotification(incoming()) && (incoming().userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && isValidId(notifId) && isValidNotification(incoming()) && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // COLLECTION: GAMES CONFIG
    match /games/{gameId} {
      allow read: if true; // Return To Player parameters and lock states are transparent
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['totalBets', 'totalVolume']))
      );
      allow delete: if isSignedIn() && isAdmin();
    }

    // COLLECTION: DEPOSITS
    match /deposits/{depositId} {
      allow read, write: if isSignedIn() && (
        isAdmin() ||
        ((resource == null || resource.data.userId == request.auth.uid) &&
         (request.resource == null || request.resource.data.userId == request.auth.uid))
      );
    }

    // COLLECTION: WITHDRAWALS
    match /withdrawals/{withdrawalId} {
      allow read, write: if isSignedIn() && (
        isAdmin() ||
        ((resource == null || resource.data.userId == request.auth.uid) &&
         (request.resource == null || request.resource.data.userId == request.auth.uid))
      );
    }

  }
}
